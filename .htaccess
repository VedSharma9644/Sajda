# -----------------------------------------------------------------------------
# SPA fallback (same idea as router.php for local dev: php -S localhost:8000 router.php)
#
# If the request is not a real file or folder, serve index.html so the app loads
# and JavaScript can read paths like /jaipur.
#
# Requires: Apache mod_rewrite and AllowOverride FileInfo (or All) for this folder.
# If the site lives in a subdirectory, set RewriteBase to that path (e.g. /myapp/).
# -----------------------------------------------------------------------------

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Prayer detail pages: /{city}/prayer-times/{prayer}
  RewriteRule ^[^/]+/prayer-times/(fajr|dhuhr|asr|maghrib|isha)/?$ /prayer-times/$1.html [L,NC]
  RewriteRule ^prayer-times/(fajr|dhuhr|asr|maghrib|isha)/?$ /prayer-times/$1.html [L,NC]
  RewriteRule ^[^/]+/style\.css$ /style.css [L,NC]
  RewriteRule ^[^/]+/js/(.+)$ /js/$1 [L,NC]

  # Let the server serve existing files and directories (CSS, JS, api.php, …)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Everything else → single-page app shell (URL in the browser stays e.g. /jaipur)
  RewriteRule ^ /index.html [L]
</IfModule>
